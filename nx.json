{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "plugins": [
    {
      "plugin": "@nx/next/plugin",
      "options": {
        "buildTargetName": "build",
        "devTargetName": "dev",
        "startTargetName": "start"
      }
    }
  ],
  "targetDefaults": {
    "dev": {
      "continuous": true
    },
    "build": {
      "dependsOn": ["^build"],
      "cache": true
    }
  }
}