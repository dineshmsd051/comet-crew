{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "strict": true,
    "paths": {
      "@comet-crew/shared/ui": ["libs/shared/ui/src/index.ts"],
      "@comet-crew/shared/state": ["libs/shared/state/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}